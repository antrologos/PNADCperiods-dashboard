# ==============================================================================
# PNADCperiods Dashboard - .gitignore
# ==============================================================================

# Credentials - NEVER commit
.Renviron
.httr-oauth

# R session files
.Rhistory
.RData
.Rproj.user/
*.Rproj

# Large data files (regenerate with scripts/precompute_*.R or via .github/scripts)
data/*.rds
data/*.fst
data/*.qs2

# But keep the data directory structure
!data/.gitkeep

# R package cache
packrat/
renv/
renv.lock

# Shiny logs
*.log
rsconnect/

# OS files
.DS_Store
Thumbs.db
desktop.ini

# IDE files
.vscode/
.idea/
*.swp
*.swo
*~

# Temporary files
*.tmp
*.temp
.Rcheck/
temp_*.R
nul

# Local outputs from .github/scripts/test_fetch_locally.R dry-runs.
# Real outputs are produced by GitHub Actions and uploaded to the
# `data-latest` release; nothing here should be committed.
output/

# Test/debug scripts in scripts/ are dev-only (do not commit).
# (Patterns are scoped so .github/scripts/test_fetch_locally.R stays tracked.)
scripts/test_*.R
scripts/test_*.html
scripts/test_*_files/
scripts/debug_*.R
scripts/validate_data.R
scripts/test_*.R
scripts/debug_*.R
scripts/fix_*.R
scripts/verify_*.R

# Test output (keep tests/testthat/*.R tracked; only ignore generated bits)
tests/testthat/_snaps/
tests/testthat/Rplots.pdf
tests/*.html
tests/*.Rout
scripts/validation_results.csv

# Claude Code
CLAUDE.md
ARCHITECTURE_PLAN.md
.claude/
